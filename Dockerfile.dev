FROM golang:1.26.1-alpine

WORKDIR /app
ENV PATH="/usr/local/go/bin:/go/bin:${PATH}"

# Dev/runtime tools:
# - bash: local install/health scripts use "bash -lc"
# - postgresql-client: module installer runs psql migrations
# - curl: healthcheck/ops tooling
RUN apk add --no-cache \
  bash \
  build-base \
  ca-certificates \
  curl \
  git \
  openssl \
  postgresql-client \
  tzdata

RUN go install github.com/air-verse/air@latest

COPY go.mod go.sum ./
RUN go mod download

# Keep source in image so container can run even without bind mount.
# In compose dev, source will be overridden by volume.
COPY . .

EXPOSE 3009

CMD ["air", "-c", ".air.toml"]
